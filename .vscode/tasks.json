    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile",
            "type": "shell",
            "command": "make -C build",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "premake5",
            "type": "shell",
            "command": "premake5 gmake2 && premake5 export-compile-commands"
        }
    ]
}